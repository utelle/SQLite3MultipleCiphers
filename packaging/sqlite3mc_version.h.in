/// \file sqlite3mc_version.h Version information for the SQLite3 Multiple Ciphers library

#ifndef SQLITE3MC_VERSION_H_
#define SQLITE3MC_VERSION_H_

#define SQLITE3MC_VERSION_MAJOR      {SQLITE3MC_VERSION_MAJOR}
#define SQLITE3MC_VERSION_MINOR      {SQLITE3MC_VERSION_MINOR}
#define SQLITE3MC_VERSION_RELEASE    {SQLITE3MC_VERSION_RELEASE}
#define SQLITE3MC_VERSION_SUBRELEASE {SQLITE3MC_VERSION_SUBRELEASE}
#define SQLITE3MC_VERSION_STRING     "SQLite3 Multiple Ciphers {SQLITE3MC_VERSION_MAJOR}.{SQLITE3MC_VERSION_MINOR}.{SQLITE3MC_VERSION_RELEASE}"

#endif /* SQLITE3MC_VERSION_H_ */
